# Skopiuj jako .env i uzupełnij wartości. Plik .env NIE wchodzi do repo (jest w .gitignore).

FLASK_APP=wsgi:app
FLASK_DEBUG=1

# Długi losowy ciąg. Wygeneruj sobie:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Lokalnie zostaw zakomentowane — domyślnie aplikacja tworzy SQLite w `instance/tindog.db`
# w katalogu repo (absolutna ścieżka, działa z każdego CWD).
# Na AGH lab odkomentuj i wskaż własną ścieżkę: sqlite:////home/<login>/data/tindog.db
# DATABASE_URL=sqlite:///instance/tindog.db

# Storage plików: local | supabase | cloudinary
STORAGE_PROVIDER=local
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# CLOUDINARY_URL=
