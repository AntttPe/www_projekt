# Skopiuj jako .env i uzupełnij wartości. Plik .env NIE wchodzi do repo (jest w .gitignore).

FLASK_APP=wsgi:app
FLASK_DEBUG=1

# Długi losowy ciąg. Wygeneruj sobie:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Lokalnie SQLite w katalogu instance/ (tworzony automatycznie).
# Na AGH lab: sqlite:////home/<login>/data/tindog.db  (baza POZA katalogiem repo!)
DATABASE_URL=sqlite:///instance/tindog.db

# Storage plików: local | supabase | cloudinary
STORAGE_PROVIDER=local
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# CLOUDINARY_URL=
